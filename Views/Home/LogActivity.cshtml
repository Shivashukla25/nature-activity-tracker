@model NatureActivityTracker.Models.ActivityModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="mb-4">
    <h2 class="fw-bold">🌿 Eco Activity Dashboard</h2>
    <p class="text-muted">Track your sustainable impact beautifully.</p>
</div>

<!-- Activity Form Card -->
<div class="card card-stat p-4 mb-4">

    <h5 class="mb-3">Log New Activity</h5>

    <form method="post" enctype="multipart/form-data">

        <div class="mb-3">
            <label class="form-label">Activity Name</label>
            <input type="text" class="form-control rounded-3" asp-for="ActivityName" required />
        </div>

        <div class="mb-3">
            <label class="form-label">Coins Earned</label>
            <input type="number" class="form-control rounded-3" asp-for="Coins" required />
        </div>

        <!-- 🔥 PROOF IMAGE UPLOAD -->
        <div class="mb-3">
            <label class="form-label">Upload Proof Image</label>
            <input type="file" name="ProofImage" class="form-control" accept="image/*" />
        </div>
        <button type="submit" class="btn btn-primary px-4 rounded-pill">
            🌱 Add Activity
        </button>

    </form>

</div>

@if (ViewBag.Message != null)
{
    <div class="alert alert-success rounded-3 shadow-sm">
        @ViewBag.Message
    </div>
}

@if (ViewBag.TotalCoins != null)
{
    <div class="alert alert-info rounded-3 shadow-sm">
        🌟 Total Coins: <strong>@ViewBag.TotalCoins</strong>
    </div>
}

<!-- Analytics Cards -->
<div class="row mb-4">

    <div class="col-md-4">
        <div class="card card-stat p-4 text-center">
            <h6 class="text-muted">Total Activities</h6>
            <h2 class="fw-bold">@ViewBag.TotalActivities</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-stat p-4 text-center">
            <h6 class="text-muted">Today's Coins</h6>
            <h2 class="fw-bold">@ViewBag.TodayCoins</h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card card-stat p-4 text-center">
            <h6 class="text-muted">This Month's Coins</h6>
            <h2 class="fw-bold">@ViewBag.MonthCoins</h2>
        </div>
    </div>

</div>

<!-- AI PANEL -->
<div class="card card-stat p-4 mb-4 text-center">

    <h5 class="mb-3">🧠 AI Sustainability Insight</h5>

    <h3 class="fw-bold">
        Eco Score: @ViewBag.EcoScore / 100
    </h3>

    <h5 class="text-success">
        Grade: @ViewBag.Grade
    </h5>

    <p class="mt-3 text-muted">
        @ViewBag.AIInsight
    </p>

</div>

<!-- Activity History Table -->
@if (ViewBag.ActivityLogs != null)
{
    var logs = ViewBag.ActivityLogs as List<NatureActivityTracker.Models.ActivityLog>;

    if (logs != null && logs.Any())
    {
        <div class="card card-stat p-4 mb-4">
            <h5 class="mb-3">Activity History</h5>

            <div class="table-responsive">
                <table class="table table-hover align-middle">

                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Activity</th>
                            <th>Coins</th>
                            <th>Proof</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in logs)
                        {
                            <tr>
                                <td>@item.Date.ToString("dd MMM yyyy HH:mm")</td>
                                <td>@item.ActivityName</td>
                                <td>@item.Coins</td>

                                <!-- PROOF IMAGE -->
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ProofImagePath))
                                    {
                                        <a href="@item.ProofImagePath" target="_blank" class="btn btn-sm btn-outline-primary">
                                            View
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No Proof</span>
                                    }
                                </td>

                                <!-- VERIFICATION STATUS -->
                                <td>
                                    @if (item.IsVerified)
                                    {
                                        <span class="badge bg-success">Verified</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">Pending</span>
                                    }
                                </td>

                                <td>
                                    <a asp-action="Delete"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-danger rounded-pill"
                                       onclick="return confirm('Delete this activity?')">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>
        </div>
    }
}

<!-- Chart Section -->
<div class="card card-stat p-4 mb-4">
    <h5 class="mb-3">Activity Analytics</h5>
    <canvas id="activityChart"></canvas>
</div>

@section Scripts {

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

var labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels));
var values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartValues));

var ctx = document.getElementById('activityChart').getContext('2d');

new Chart(ctx, {
    type: 'bar',
    data: {
        labels: labels,
        datasets: [{
            label: 'Coins Earned',
            data: values,
            backgroundColor: '#84a98c',
            borderRadius: 8
        }]
    },
    options: {
        responsive: true,
        scales: {
            y: {
                beginAtZero: true
            }
        }
    }
});

</script>

}