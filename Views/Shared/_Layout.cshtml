<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EcoImpact</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- FontAwesome Icons -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

    <style>
    body {
        background-color: #fdfaf6;
        font-family: 'Segoe UI', sans-serif;
    }

    .navbar {
        background-color: #a8d5ba;
    }

    .navbar-brand,
    .nav-link {
        color: #2f3e46 !important;
        font-weight: 500;
    }

    .nav-link:hover {
        color: #52796f !important;
    }

    .card-stat {
        border-radius: 18px;
        border: none;
        background: #ffffff;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
        transition: 0.3s ease;
    }

    .card-stat:hover {
        transform: translateY(-4px);
    }

    footer {
        margin-top: 60px;
        padding: 25px 0;
        background-color: #cad2c5;
        color: #344e41;
        text-align: center;
        font-weight: 500;
    }

    .btn-primary {
        background-color: #84a98c;
        border: none;
    }

    .btn-primary:hover {
        background-color: #52796f;
    }

    table {
        background-color: white;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 5px 15px rgba(0,0,0,0.05);
    }

    th {
        background-color: #e9f5f2;
        color: #344e41;
    }

    td {
        color: #3a5a40;
    }
</style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" href="/">🌱 EcoImpact</a>

            <div class="collapse navbar-collapse">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/LogActivity">Dashboard</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Identity/Account/Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Identity/Account/Register">Register</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container mt-4">
        @RenderBody()
    </div>

    <!-- Footer -->
    <footer>
        © 2026 EcoImpact | Sustainable Activity Tracker
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>